      "cssOutput": ".dialog {\n  display: flex;\n  width: 358px;\n  padding: var(--app-foundations-spacing-sp-4, 16px);\n  flex-direction: column;\n  align-items: flex-start;\n  gap: var(--app-foundations-spacing-sp-6, 24px);\n  border-radius: var(--app-foundations-radius-large, 20px);\n  background: var(--new-neutrals-white, #FFF);\n}\n\n.dialog__image {\n  border-radius: var(--app-foundations-radius-small, 8px);\n  border: 0.81px solid var(--new-neutrals-light-grey, #DDDFEB);\n  height: 227px;\n}\n\n.dialog__title {\n  color: var(--new-neutrals-black, #1A1F3C);\n  font-size: 20px;\n  font-weight: 600;\n  line-height: 24px;\n  letter-spacing: 0.38px;\n}\n\n.dialog__body {\n  color: var(--new-neutrals-darkest-grey, #565C79);\n  font-size: 13px;\n  font-weight: 400;\n  line-height: 18px;\n}\n\n.dialog__btn-primary {\n  padding: 12px var(--app-foundations-spacing-sp-5, 20px);\n  background: var(--new-neutrals-black, #1A1F3C);\n  border-radius: var(--app-foundations-radius-full, 24px);\n  color: var(--new-neutrals-white, #FFF);\n  font-size: 13px;\n  font-weight: 600;\n}"
